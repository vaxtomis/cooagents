# Optional: Feishu webhook for workflow event notifications
FEISHU_WEBHOOK_URL=https://open.feishu.cn/open-apis/bot/v2/hook/replace_me
COOAGENTS_CONFIG_DIR=config
COOAGENTS_COOP_DIR=.coop

# OSS 启用时必需（storage.oss.enabled=true）。
# Phase 1–7b 把 OSS 作为只写备份目标：每次工作区写入由
# WorkspaceFileRegistry.register() 同步 PUT 到 OSS，不做反向拉取。
# Phase 8 在 Agent 执行节点引入双向 materialize / CAS。
OSS_BUCKET=
OSS_REGION=
OSS_ENDPOINT=
OSS_ACCESS_KEY_ID=
OSS_ACCESS_KEY_SECRET=
