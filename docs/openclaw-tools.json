{
  "tools": [
    {
      "name": "ensure_repo",
      "description": "确保仓库存在 — 创建任务前必须调用。已有 git 仓库返回 exists，不存在时 clone 或 init",
      "method": "POST",
      "endpoint": "/api/v1/repos/ensure",
      "parameters": {
        "repo_path": {"type": "string", "description": "本地仓库路径", "required": true},
        "repo_url": {"type": "string", "description": "远程仓库 URL（可选，提供时 clone）"}
      }
    },
    {
      "name": "create_task",
      "description": "创建新的工作流任务（repo_path 必须是已有的 git 仓库，否则返回 400）",
      "method": "POST",
      "endpoint": "/api/v1/runs",
      "parameters": {
        "ticket": {"type": "string", "description": "任务标识符", "required": true},
        "repo_path": {"type": "string", "description": "代码仓库路径", "required": true},
        "description": {"type": "string", "description": "任务描述"},
        "preferences": {"type": "object", "description": "偏好设置（如指定主机）"},
        "repo_url": {"type": "string", "description": "远程仓库 URL（仅记录，不触发 clone）"}
      }
    },
    {
      "name": "list_tasks",
      "description": "列出所有工作流任务",
      "method": "GET",
      "endpoint": "/api/v1/runs",
      "parameters": {
        "status": {"type": "string", "description": "按状态过滤: running/completed/failed/cancelled"},
        "limit": {"type": "integer", "description": "返回数量限制", "default": 20}
      }
    },
    {
      "name": "get_task_status",
      "description": "获取任务详细状态",
      "method": "GET",
      "endpoint": "/api/v1/runs/{run_id}",
      "parameters": {
        "run_id": {"type": "string", "description": "任务运行ID", "required": true}
      }
    },
    {
      "name": "tick_task",
      "description": "推进任务到下一阶段（幂等操作，可安全重复调用）",
      "method": "POST",
      "endpoint": "/api/v1/runs/{run_id}/tick",
      "parameters": {
        "run_id": {"type": "string", "description": "任务运行ID", "required": true}
      }
    },
    {
      "name": "upload_requirement",
      "description": "上传已有的需求文档文件创建任务 — 跳过需求收集和需求审批阶段，直接进入设计。适用于用户已经编写好需求文档（.md 或 .docx）的场景，无需人工审批需求内容",
      "method": "POST",
      "endpoint": "/api/v1/runs/upload-requirement",
      "content_type": "multipart/form-data",
      "parameters": {
        "file": {"type": "file", "description": "需求文档文件（.md 或 .docx，docx 会自动转为 markdown）", "required": true},
        "ticket": {"type": "string", "description": "任务标识符", "required": true},
        "repo_path": {"type": "string", "description": "代码仓库路径", "required": true},
        "description": {"type": "string", "description": "任务描述"},
        "notify_channel": {"type": "string", "description": "通知渠道"},
        "notify_to": {"type": "string", "description": "通知目标"},
        "repo_url": {"type": "string", "description": "远程仓库 URL（仅记录）"},
        "design_agent": {"type": "string", "enum": ["claude", "codex"], "description": "设计阶段 Agent"},
        "dev_agent": {"type": "string", "enum": ["claude", "codex"], "description": "开发阶段 Agent"}
      },
      "response": {"id": "<run_id>", "current_stage": "DESIGN_QUEUED"},
      "note": "此接口创建任务并自动审批需求，跳过 REQ_COLLECTING → REQ_REVIEW，直接到达 DESIGN_QUEUED"
    },
    {
      "name": "submit_requirement",
      "description": "提交需求文档内容并进入需求审批环节 — 适用于 Agent 与用户对话过程中生成的需求文档，提交后进入 REQ_REVIEW 阶段等待用户审批确认",
      "method": "POST",
      "endpoint": "/api/v1/runs/{run_id}/submit-requirement",
      "parameters": {
        "run_id": {"type": "string", "description": "任务运行ID", "required": true},
        "content": {"type": "string", "description": "需求文档内容（Markdown格式）", "required": true}
      },
      "response": {"id": "<run_id>", "current_stage": "REQ_REVIEW"},
      "note": "提交后需 tick 推进到 REQ_REVIEW，用户审批通过后才进入设计阶段"
    },
    {
      "name": "approve_gate",
      "description": "审批通过指定阶段门控",
      "method": "POST",
      "endpoint": "/api/v1/runs/{run_id}/approve",
      "parameters": {
        "run_id": {"type": "string", "description": "任务运行ID", "required": true},
        "gate": {"type": "string", "enum": ["req", "design", "dev"], "description": "门控名称", "required": true},
        "by": {"type": "string", "description": "审批人", "required": true},
        "comment": {"type": "string", "description": "审批备注"}
      }
    },
    {
      "name": "reject_gate",
      "description": "驳回指定阶段门控",
      "method": "POST",
      "endpoint": "/api/v1/runs/{run_id}/reject",
      "parameters": {
        "run_id": {"type": "string", "description": "任务运行ID", "required": true},
        "gate": {"type": "string", "enum": ["req", "design", "dev"], "description": "门控名称", "required": true},
        "by": {"type": "string", "description": "驳回人", "required": true},
        "reason": {"type": "string", "description": "驳回原因", "required": true}
      }
    },
    {
      "name": "retry_task",
      "description": "重试失败的任务",
      "method": "POST",
      "endpoint": "/api/v1/runs/{run_id}/retry",
      "parameters": {
        "run_id": {"type": "string", "description": "任务运行ID", "required": true},
        "by": {"type": "string", "description": "操作人", "required": true},
        "note": {"type": "string", "description": "备注"}
      }
    },
    {
      "name": "recover_task",
      "description": "恢复中断的任务",
      "method": "POST",
      "endpoint": "/api/v1/runs/{run_id}/recover",
      "parameters": {
        "run_id": {"type": "string", "description": "任务运行ID", "required": true},
        "action": {"type": "string", "enum": ["resume", "redo", "manual"], "description": "恢复策略", "required": true}
      }
    },
    {
      "name": "cancel_task",
      "description": "取消任务",
      "method": "DELETE",
      "endpoint": "/api/v1/runs/{run_id}",
      "parameters": {
        "run_id": {"type": "string", "description": "任务运行ID", "required": true},
        "cleanup": {"type": "boolean", "description": "是否清理 worktree", "default": false}
      }
    },
    {
      "name": "list_artifacts",
      "description": "列出任务的产物文件",
      "method": "GET",
      "endpoint": "/api/v1/runs/{run_id}/artifacts",
      "parameters": {
        "run_id": {"type": "string", "description": "任务运行ID", "required": true},
        "kind": {"type": "string", "description": "按类型过滤: req/design/adr/code/test-report"},
        "status": {"type": "string", "description": "按状态过滤: draft/submitted/approved/rejected"}
      }
    },
    {
      "name": "get_artifact_content",
      "description": "获取产物文件内容",
      "method": "GET",
      "endpoint": "/api/v1/runs/{run_id}/artifacts/{artifact_id}/content",
      "parameters": {
        "run_id": {"type": "string", "description": "任务运行ID", "required": true},
        "artifact_id": {"type": "integer", "description": "产物ID", "required": true}
      }
    },
    {
      "name": "get_run_trace",
      "description": "获取任务的完整事件链路，含阶段转换、错误、耗时汇总",
      "method": "GET",
      "endpoint": "/api/v1/runs/{run_id}/trace",
      "parameters": {
        "run_id": {"type": "string", "description": "任务运行ID", "required": true},
        "level": {"type": "string", "enum": ["debug", "info", "warning", "error"], "description": "最低日志级别过滤", "default": "info"},
        "span_type": {"type": "string", "description": "按 span 类型过滤: request/run/job/system"},
        "limit": {"type": "integer", "description": "返回事件数量限制", "default": 200},
        "offset": {"type": "integer", "description": "分页偏移量", "default": 0}
      }
    },
    {
      "name": "get_job_diagnosis",
      "description": "获取 Job 的故障诊断信息，含错误摘要、堆栈、耗时、轮次、主机状态",
      "method": "GET",
      "endpoint": "/api/v1/jobs/{job_id}/diagnosis",
      "parameters": {
        "job_id": {"type": "string", "description": "Job ID", "required": true},
        "level": {"type": "string", "enum": ["debug", "info", "warning", "error"], "description": "最低日志级别过滤", "default": "info"}
      }
    },
    {
      "name": "get_trace",
      "description": "通过 trace_id 追踪完整请求链路（从 HTTP 请求到 run 到 job）",
      "method": "GET",
      "endpoint": "/api/v1/traces/{trace_id}",
      "parameters": {
        "trace_id": {"type": "string", "description": "链路追踪ID（可从 HTTP 响应头 X-Trace-Id 获取）", "required": true},
        "level": {"type": "string", "enum": ["debug", "info", "warning", "error"], "description": "最低日志级别过滤", "default": "info"}
      }
    }
  ]
}
